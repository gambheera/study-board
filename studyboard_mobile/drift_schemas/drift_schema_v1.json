  "fixed_sql": [
    {
      "name": "students",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"students\" (\"id\" TEXT NOT NULL, \"name\" TEXT NOT NULL, \"email\" TEXT NOT NULL, \"district\" TEXT NOT NULL, \"school\" TEXT NOT NULL, \"fcm_token\" TEXT NULL, \"notifications_enabled\" INTEGER NOT NULL DEFAULT 1 CHECK (\"notifications_enabled\" IN (0, 1)), \"deactivated_at\" TEXT NULL, \"deleted_at\" TEXT NULL, \"last_active_at\" TEXT NOT NULL, \"created_at\" TEXT NOT NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "subjects",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"subjects\" (\"id\" TEXT NOT NULL, \"name\" TEXT NOT NULL, \"quiz_pass_threshold\" REAL NOT NULL DEFAULT 0.8, \"content_version\" INTEGER NOT NULL DEFAULT 1, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "topics",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"topics\" (\"id\" TEXT NOT NULL, \"subject_id\" TEXT NOT NULL, \"title\" TEXT NOT NULL, \"order_index\" INTEGER NOT NULL DEFAULT 0, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "lessons",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"lessons\" (\"id\" TEXT NOT NULL, \"topic_id\" TEXT NOT NULL, \"title\" TEXT NOT NULL, \"content_text\" TEXT NOT NULL, \"content_track\" TEXT NOT NULL, \"order_index\" INTEGER NOT NULL DEFAULT 0, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "lesson_tasks",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"lesson_tasks\" (\"id\" TEXT NOT NULL, \"student_id\" TEXT NOT NULL, \"lesson_id\" TEXT NOT NULL, \"task_status\" TEXT NOT NULL DEFAULT 'backlog', \"curiosity_completed\" INTEGER NOT NULL DEFAULT 0 CHECK (\"curiosity_completed\" IN (0, 1)), \"created_at\" TEXT NOT NULL, \"updated_at\" TEXT NOT NULL, PRIMARY KEY (\"id\"), CHECK (task_status IN ('backlog', 'todo', 'in_progress', 'done')), UNIQUE (student_id, lesson_id));"
        }
      ]
    },
    {
      "name": "quiz_questions",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"quiz_questions\" (\"id\" TEXT NOT NULL, \"lesson_id\" TEXT NOT NULL, \"question_text\" TEXT NOT NULL, \"option_a\" TEXT NOT NULL, \"option_b\" TEXT NOT NULL, \"option_c\" TEXT NOT NULL, \"option_d\" TEXT NOT NULL, \"correct_option\" TEXT NOT NULL, \"order_index\" INTEGER NOT NULL DEFAULT 0, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "quiz_attempts",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"quiz_attempts\" (\"id\" TEXT NOT NULL, \"student_id\" TEXT NOT NULL, \"lesson_id\" TEXT NOT NULL, \"score\" REAL NOT NULL, \"passed\" INTEGER NOT NULL CHECK (\"passed\" IN (0, 1)), \"attempted_at\" TEXT NOT NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "past_paper_questions",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"past_paper_questions\" (\"id\" TEXT NOT NULL, \"lesson_id\" TEXT NOT NULL, \"topic_id\" TEXT NOT NULL, \"question_text\" TEXT NOT NULL, \"year\" INTEGER NULL, \"order_index\" INTEGER NOT NULL DEFAULT 0, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "survey_responses",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"survey_responses\" (\"id\" TEXT NOT NULL, \"student_id\" TEXT NOT NULL, \"responses\" TEXT NOT NULL, \"responded_at\" TEXT NOT NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "nudge_events",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"nudge_events\" (\"id\" TEXT NOT NULL, \"student_id\" TEXT NOT NULL, \"sent_at\" TEXT NOT NULL, \"fcm_message_id\" TEXT NULL, \"status\" TEXT NOT NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "sessions",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"sessions\" (\"id\" TEXT NOT NULL, \"student_id\" TEXT NOT NULL, \"started_at\" TEXT NOT NULL, \"ended_at\" TEXT NULL, \"attributed_nudge_id\" TEXT NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "sync_queue",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"sync_queue\" (\"id\" TEXT NOT NULL, \"entity_type\" TEXT NOT NULL, \"entity_id\" TEXT NOT NULL, \"operation\" TEXT NOT NULL, \"payload\" TEXT NOT NULL, \"created_at\" TEXT NOT NULL, \"retry_count\" INTEGER NOT NULL DEFAULT 0, PRIMARY KEY (\"id\"));"
        }
      ]
    },
